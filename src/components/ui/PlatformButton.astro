---
import type { DeliveryPlatform } from '@/config/site';

interface Props {
  platform: DeliveryPlatform;
}
const { platform } = Astro.props;
---

<a
  class="platform"
  href={platform.url}
  target="_blank"
  rel="noopener noreferrer"
  data-demo={platform.demo ? '' : undefined}
>
  <span class="platform__name">{platform.name}</span>
  <svg viewBox="0 0 20 20" width="15" height="15" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
    <path d="M6 14 14 6M8 6h6v6" />
  </svg>
</a>

<style>
  .platform {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
    min-height: 56px;
    padding: 0 1.35rem;
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    color: var(--text);
    font-size: var(--fs-body);
    letter-spacing: 0.01em;
    background: color-mix(in srgb, var(--surface) 40%, transparent);
    transition:
      border-color var(--dur-2) var(--ease-out),
      transform var(--dur-1) var(--ease-out),
      background-color var(--dur-2) var(--ease-out);
  }
  .platform:hover {
    border-color: var(--brass);
    transform: translateY(-2px);
    background: color-mix(in srgb, var(--surface) 70%, transparent);
  }
  .platform__name {
    font-weight: 500;
  }
  .platform svg {
    color: var(--brass);
    flex-shrink: 0;
  }
  [dir='rtl'] .platform svg {
    transform: scaleX(-1);
  }
  @media (prefers-reduced-motion: reduce) {
    .platform {
      transition: border-color var(--dur-2);
    }
    .platform:hover {
      transform: none;
    }
  }
</style>
