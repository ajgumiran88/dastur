---
/**
 * Button / link. Renders an <a> when href is set, else a <button>.
 * Variants: primary (palm fill), ghost (hairline), link (underline).
 */
interface Props {
  href?: string;
  variant?: 'primary' | 'ghost' | 'link';
  size?: 'md' | 'lg';
  magnetic?: boolean;
  external?: boolean;
  type?: 'button' | 'submit';
  class?: string;
  id?: string;
  'aria-label'?: string;
  'data-order'?: string;
}
const {
  href,
  variant = 'primary',
  size = 'md',
  magnetic = false,
  external = false,
  type = 'button',
  class: className = '',
  id,
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
const extra = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<Tag
  id={id}
  href={href}
  type={href ? undefined : type}
  data-magnetic={magnetic ? '' : undefined}
  class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
  {...extra}
  {...rest}
>
  <span class="btn__label"><slot /></span>
</Tag>

<style>
  .btn {
    --btn-bg: var(--palm);
    --btn-fg: #fff;
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6em;
    min-height: 44px;
    padding: 0.85em 1.6em;
    border-radius: var(--r-pill);
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
    cursor: pointer;
    transition:
      transform var(--dur-1) var(--ease-out),
      background-color var(--dur-2) var(--ease-out),
      color var(--dur-2) var(--ease-out),
      border-color var(--dur-2) var(--ease-out),
      box-shadow var(--dur-2) var(--ease-out);
    will-change: transform;
  }
  [lang='ar'] .btn {
    letter-spacing: 0;
    text-transform: none;
    font-weight: 700;
  }
  .btn--lg {
    padding: 1.05em 2em;
    font-size: var(--fs-body);
  }

  .btn--primary {
    background: var(--btn-bg);
    color: var(--btn-fg);
    box-shadow: var(--shadow-md);
  }
  .btn--primary:hover {
    background: var(--palm-400);
    transform: translateY(-2px);
  }
  .btn--primary:active {
    transform: translateY(0);
  }

  .btn--ghost {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }
  .btn--ghost:hover {
    border-color: var(--brass);
    color: var(--text);
    transform: translateY(-2px);
  }
  .section--indigo .btn--ghost,
  .section--oud .btn--ghost,
  .section--palm .btn--ghost {
    color: var(--sand);
    border-color: color-mix(in srgb, var(--sand) 40%, transparent);
  }
  .section--indigo .btn--ghost:hover,
  .section--oud .btn--ghost:hover,
  .section--palm .btn--ghost:hover {
    border-color: var(--brass-300);
  }

  .btn--link {
    padding: 0.4em 0;
    min-height: 0;
    background: none;
    color: var(--text);
    text-transform: none;
    letter-spacing: 0.02em;
    border-radius: 0;
  }
  .btn--link .btn__label {
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 0% 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    padding-bottom: 2px;
    transition: background-size var(--dur-2) var(--ease-out);
  }
  .btn--link:hover .btn__label {
    background-size: 100% 1px;
  }

  @media (prefers-reduced-motion: reduce) {
    .btn {
      transition: background-color var(--dur-2), color var(--dur-2);
    }
    .btn:hover {
      transform: none;
    }
  }
</style>
