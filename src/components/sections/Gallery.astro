---
import { Image } from 'astro:assets';
import Section from '@/components/ui/Section.astro';
import Motif from '@/components/ui/Motif.astro';
import { galleryItems } from '@/config/gallery';
import { t, type Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const accentVar: Record<string, string> = {
  palm: 'var(--palm)',
  oud: 'var(--oud)',
  indigo: 'var(--indigo)',
  sand: 'var(--sand-300)',
};
---

<Section id="gallery" theme="sand" labelledby="gal-title">
  <div class="container">
    <div class="gal__head" data-animate>
      <p class="eyebrow"><Motif name="diamond" />{t(locale, 'gallery.eyebrow')}</p>
      <h2 id="gal-title" class="gal__title">{t(locale, 'gallery.title')}</h2>
      <p class="lead gal__intro measure">{t(locale, 'gallery.intro')}</p>
    </div>

    <div class="gal__grid" data-animate data-animate-delay="80">
      {
        galleryItems.map((item) => (
          <figure class={`gal__item gal__item--${item.span}`}>
            {item.kind === 'photo' && item.image ? (
              <Image
                src={item.image}
                alt={item.alt[locale]}
                widths={[320, 560, 820]}
                sizes="(max-width: 700px) 90vw, 40vw"
                loading="lazy"
                class="gal__img"
              />
            ) : (
              <div
                class="gal__demo"
                style={`--g-accent:${accentVar[item.accent ?? 'sand']}`}
                data-demo
                role="img"
                aria-label={item.alt[locale]}
              >
                <Motif name={item.motif ?? 'diamond'} />
                {item.label && <span class="gal__label">{item.label[locale]}</span>}
                <span class="gal__demoTag">{t(locale, 'gallery.demoImage')}</span>
              </div>
            )}
          </figure>
        ))
      }
    </div>
  </div>
</Section>

<style>
  .gal__head {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    max-width: 44ch;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .gal__title {
    font-size: var(--fs-h2);
  }
  .gal__intro {
    color: var(--text-muted);
  }

  /* Multi-column masonry: robust, gap-free, editorial. Items keep varied
     aspect ratios for asymmetric rhythm. */
  .gal__grid {
    columns: 2;
    column-gap: 0.9rem;
  }
  .gal__item {
    position: relative;
    break-inside: avoid;
    margin: 0 0 0.9rem;
    overflow: hidden;
    border-radius: var(--r-md);
    background: var(--sand-100);
    border: 1px solid var(--hairline);
    display: block;
    width: 100%;
  }
  /* Aspect ratios drive the asymmetry (span name = shape) */
  .gal__item--std {
    aspect-ratio: 1 / 1;
  }
  .gal__item--wide,
  .gal__item--big {
    aspect-ratio: 4 / 3;
  }
  .gal__item--tall {
    aspect-ratio: 3 / 4;
  }
  .gal__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-4) var(--ease-out);
  }
  .gal__item:hover .gal__img {
    transform: scale(1.05);
  }

  .gal__demo {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    gap: 0.6rem;
    grid-auto-flow: row;
    align-content: center;
    background: radial-gradient(
      120% 100% at 50% 0%,
      color-mix(in srgb, var(--g-accent) 22%, var(--sand-100)) 0%,
      var(--sand-100) 72%
    );
    color: var(--g-accent);
    text-align: center;
    padding: 1rem;
  }
  .gal__demo :global(.motif) {
    width: 2.2rem;
    height: 2.2rem;
  }
  .gal__label {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--oud);
  }
  .gal__demoTag {
    position: absolute;
    inset-block-end: 0.6rem;
    inset-inline: 0;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--oud-muted);
    opacity: 0.7;
  }

  @media (min-width: 760px) {
    .gal__grid {
      columns: 3;
      column-gap: 1rem;
    }
    .gal__item {
      margin-bottom: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gal__img {
      transition: none;
    }
    .gal__item:hover .gal__img {
      transform: none;
    }
  }
</style>
