---
import { Image } from 'astro:assets';
import Section from '@/components/ui/Section.astro';
import Motif from '@/components/ui/Motif.astro';
import PlatformButton from '@/components/ui/PlatformButton.astro';
import { site } from '@/config/site';
import { t, type Locale } from '@/lib/i18n';
import { orderWaLink, telLink } from '@/lib/links';
import skyline from '@/assets/illustration/skyline.png';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const platforms = site.deliveryPlatforms.filter((p) => p.enabled);

const facts = [
  { key: 'locations', value: site.serviceAreas.join(' · ') },
  { key: 'minOrder', value: site.minOrder },
  { key: 'hours', value: site.hours },
  { key: 'eta', value: site.deliveryEta },
  { key: 'contact', value: site.contact.whatsapp },
];
---

<Section id="delivery" theme="indigo" labelledby="del-title">
  <div class="del__skyline" aria-hidden="true">
    <Image src={skyline} alt="" widths={[900, 1600]} sizes="100vw" loading="lazy" />
  </div>

  <div class="container del">
    <div class="del__head" data-animate>
      <p class="eyebrow"><Motif name="diamond" />{t(locale, 'delivery.eyebrow')}</p>
      <h2 id="del-title" class="del__title">{t(locale, 'delivery.title')}</h2>
      <p class="lead del__body measure">{t(locale, 'delivery.body')}</p>
    </div>

    <div class="del__paths" data-animate data-animate-delay="100">
      <a class="path path--primary" href={orderWaLink(locale)} target="_blank" rel="noopener noreferrer">
        <span class="path__ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 0 0-7.7 13.6L3 21l4.6-1.2A9 9 0 1 0 12 3Z" /><path d="M8.5 9.5c.4 3 2.9 5.6 6 6l1.2-1.6 2 .8-.4 2c-4.4.9-9.3-4-8.4-8.4l2-.4.8 2Z" /></svg>
        </span>
        <span class="path__text">
          <span class="path__title">{t(locale, 'delivery.whatsapp')}</span>
          <span class="path__desc">{t(locale, 'delivery.whatsappDesc')}</span>
        </span>
        <span class="path__arrow" aria-hidden="true">
          <svg viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 10h10M11 6l4 4-4 4" /></svg>
        </span>
      </a>

      <a class="path" href={site.orderOnlineUrl} data-demo>
        <span class="path__ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h16l-1.2 11a2 2 0 0 1-2 1.8H7.2a2 2 0 0 1-2-1.8L4 7Z" /><path d="M8.5 7a3.5 3.5 0 0 1 7 0" /></svg>
        </span>
        <span class="path__text">
          <span class="path__title">{t(locale, 'delivery.direct')}</span>
          <span class="path__desc">{t(locale, 'delivery.directDesc')}</span>
        </span>
        <span class="path__arrow" aria-hidden="true">
          <svg viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 10h10M11 6l4 4-4 4" /></svg>
        </span>
      </a>
    </div>

    {
      platforms.length > 0 && (
        <div class="del__platforms" data-animate data-animate-delay="160">
          <p class="del__platformsLabel caps">{t(locale, 'delivery.platformsLabel')}</p>
          <div class="del__platformGrid">
            {platforms.map((p) => (
              <PlatformButton platform={p} />
            ))}
          </div>
        </div>
      )
    }

    <div class="del__facts" data-animate data-animate-delay="200">
      <p class="del__demo" role="note">
        <Motif name="diamond" />{t(locale, 'delivery.demoNote')}
      </p>
      <dl class="del__factGrid">
        {
          facts.map((f) => (
            <div class="del__fact">
              <dt>{t(locale, `delivery.fields.${f.key}`)}</dt>
              <dd>
                {f.key === 'contact' ? (
                  <a href={telLink(f.value)}>{f.value}</a>
                ) : (
                  f.value
                )}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</Section>

<style>
  #delivery {
    position: relative;
    overflow: clip;
  }
  .del__skyline {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    line-height: 0;
    opacity: 0.08;
    filter: brightness(0) invert(1);
    -webkit-mask-image: linear-gradient(to top, black 40%, transparent 90%);
    mask-image: linear-gradient(to top, black 40%, transparent 90%);
    pointer-events: none;
  }
  .del__skyline :global(img) {
    width: 100%;
    height: auto;
  }
  .del {
    position: relative;
    z-index: 1;
  }
  .del__head {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    text-align: center;
    align-items: center;
    max-width: 46ch;
    margin-inline: auto;
  }
  .del__title {
    font-size: var(--fs-h2);
    color: var(--sand);
  }
  .del__body {
    color: var(--on-dark-muted);
  }

  .del__paths {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 2.5rem;
  }
  .path {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 1.35rem 1.5rem;
    border-radius: var(--r-md);
    border: 1px solid color-mix(in srgb, var(--sand) 20%, transparent);
    background: color-mix(in srgb, var(--indigo-800) 60%, transparent);
    color: var(--sand);
    transition:
      transform var(--dur-1) var(--ease-out),
      border-color var(--dur-2) var(--ease-out),
      background-color var(--dur-2) var(--ease-out);
  }
  .path:hover {
    transform: translateY(-2px);
    border-color: var(--brass-300);
  }
  .path--primary {
    background: var(--palm);
    border-color: var(--palm);
  }
  .path--primary:hover {
    background: var(--palm-400);
    border-color: var(--palm-400);
  }
  .path__ico {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: var(--r-sm);
    background: color-mix(in srgb, var(--sand) 12%, transparent);
    color: var(--sand);
  }
  .path__text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }
  .path__title {
    font-size: var(--fs-h4);
    font-family: var(--font-display);
    font-weight: 600;
  }
  [lang='ar'] .path__title {
    font-family: var(--font-arabic-display);
  }
  .path__desc {
    font-size: var(--fs-small);
    color: color-mix(in srgb, var(--sand) 78%, transparent);
  }
  .path__arrow {
    flex-shrink: 0;
    color: var(--brass-300);
  }
  .path--primary .path__arrow {
    color: var(--sand);
  }
  [dir='rtl'] .path__arrow svg {
    transform: scaleX(-1);
  }

  .del__platforms {
    margin-top: 2.5rem;
    text-align: center;
  }
  .del__platformsLabel {
    color: var(--brass-300);
    margin-bottom: 1.1rem;
  }
  .del__platformGrid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
    max-width: 640px;
    margin-inline: auto;
  }
  .del__platformGrid :global(.platform) {
    color: var(--sand);
    border-color: color-mix(in srgb, var(--sand) 26%, transparent);
    background: color-mix(in srgb, var(--indigo-800) 50%, transparent);
  }

  .del__facts {
    margin-top: 3rem;
  }
  .del__demo {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    max-width: 66ch;
    margin: 0 auto 2rem;
    padding: 0.75rem 1.1rem;
    background: color-mix(in srgb, var(--brass) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--brass-300) 40%, transparent);
    border-radius: var(--r-sm);
    font-size: 0.76rem;
    color: var(--on-dark-muted);
    text-align: start;
  }
  .del__demo :global(.motif) {
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    color: var(--brass-300);
    margin-top: 0.15rem;
  }
  .del__factGrid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 1.25rem;
    max-width: 820px;
    margin-inline: auto;
  }
  .del__fact dt {
    font-size: 0.64rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brass-300);
    margin-bottom: 0.3rem;
  }
  [lang='ar'] .del__fact dt {
    letter-spacing: 0.02em;
  }
  .del__fact dd {
    margin: 0;
    color: var(--sand);
    font-size: var(--fs-small);
  }
  .del__fact a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (min-width: 720px) {
    .del__paths {
      grid-template-columns: repeat(2, 1fr);
    }
    .del__platformGrid {
      grid-template-columns: repeat(4, 1fr);
    }
    .del__factGrid {
      grid-template-columns: repeat(5, 1fr);
    }
  }
</style>
