---
import Section from '@/components/ui/Section.astro';
import Motif from '@/components/ui/Motif.astro';
import { testimonials } from '@/config/testimonials';
import { t, type Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<Section id="testimonials" theme="sand" labelledby="tst-title">
  <div class="container">
    <div class="tst__head" data-animate>
      <p class="eyebrow"><Motif name="diamond" />{t(locale, 'testimonials.eyebrow')}</p>
      <h2 id="tst-title" class="tst__title">{t(locale, 'testimonials.title')}</h2>
    </div>

    <p class="tst__demo" role="note">
      <Motif name="diamond" />{t(locale, 'testimonials.demoNote')}
    </p>

    <ul class="tst__grid" role="list">
      {
        testimonials.map((item, i) => (
          <li class="tst__card" data-animate data-animate-delay={i * 90}>
            <span class="tst__quoteMark" aria-hidden="true">&ldquo;</span>
            <blockquote class="tst__quote">{item.quote[locale]}</blockquote>
            <figcaption class="tst__by">
              <span class="tst__author">{item.author}</span>
              <span class="tst__loc">{item.location}</span>
            </figcaption>
          </li>
        ))
      }
    </ul>
  </div>
</Section>

<style>
  .tst__head {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    text-align: center;
    align-items: center;
  }
  .tst__title {
    font-size: var(--fs-h2);
  }
  .tst__demo {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    max-width: 62ch;
    margin: 1.5rem auto 0;
    padding: 0.75rem 1.1rem;
    background: color-mix(in srgb, var(--brass) 12%, var(--surface));
    border: 1px solid color-mix(in srgb, var(--brass) 30%, transparent);
    border-radius: var(--r-sm);
    font-size: 0.76rem;
    color: var(--oud-muted);
  }
  .tst__demo :global(.motif) {
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    color: var(--brass-600);
    margin-top: 0.15rem;
  }

  .tst__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
    list-style: none;
    padding: 0;
  }
  .tst__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2.25rem 1.75rem 1.75rem;
    background: var(--surface-raised);
    border: 1px solid var(--hairline);
    border-radius: var(--r-md);
  }
  .tst__quoteMark {
    font-family: var(--font-display);
    font-size: 3.5rem;
    line-height: 0.5;
    color: var(--brass-300);
    height: 1.2rem;
  }
  .tst__quote {
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.4;
    color: var(--text);
    margin: 0;
    flex: 1;
  }
  [lang='ar'] .tst__quote {
    font-family: var(--font-arabic-display);
    font-size: 1.15rem;
    line-height: 1.7;
  }
  .tst__by {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 1rem;
    border-top: 1px solid var(--hairline);
  }
  .tst__author {
    font-weight: 500;
  }
  .tst__loc {
    font-size: var(--fs-small);
    color: var(--text-muted);
  }

  @media (min-width: 720px) {
    .tst__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
