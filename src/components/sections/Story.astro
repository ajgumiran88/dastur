---
import { Image } from 'astro:assets';
import Section from '@/components/ui/Section.astro';
import Motif from '@/components/ui/Motif.astro';
import { t, type Locale } from '@/lib/i18n';
import heritage from '@/assets/story/heritage-landscape.jpg';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const symbols = [
  { key: 'land', motif: 'palm' as const },
  { key: 'sea', motif: 'dhow' as const },
  { key: 'craft', motif: 'windtower' as const },
];
---

<Section id="story" theme="sand" labelledby="story-title">
  <div class="container story">
    <div class="story__text">
      <p class="eyebrow" data-animate>
        <Motif name="diamond" />{t(locale, 'story.eyebrow')}
      </p>
      <h2 class="story__title" id="story-title" data-animate data-animate-delay="60">
        {t(locale, 'story.title')}
      </h2>
      <div class="story__body" data-animate data-animate-delay="120">
        <p>{t(locale, 'story.p1')}</p>
        <p>{t(locale, 'story.p2')}</p>
        <p>{t(locale, 'story.p3')}</p>
      </div>

      <div class="story__symbols" data-animate data-animate-delay="180">
        <ul role="list">
          {
            symbols.map((s) => (
              <li class="symbol">
                <span class="symbol__ico"><Motif name={s.motif} /></span>
                <div>
                  <h3 class="symbol__title">{t(locale, `story.symbols.${s.key}`)}</h3>
                  <p class="symbol__desc">{t(locale, `story.symbols.${s.key}Desc`)}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="story__media" data-animate data-animate-delay="120">
      <figure class="story__figure">
        <Image
          src={heritage}
          alt="A sepia illustration of an Emirati coast — dhows, wind towers and a walled town by the water."
          widths={[520, 780, 1040]}
          sizes="(max-width: 900px) 90vw, 460px"
          loading="lazy"
          class="story__img"
        />
        <div class="story__arch" aria-hidden="true"></div>
      </figure>
      <span class="story__caption caps">Land & Sea</span>
    </div>
  </div>
</Section>

<style>
  .story {
    display: grid;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: center;
  }
  .story__text {
    display: flex;
    flex-direction: column;
    gap: 1.3rem;
  }
  .story__title {
    font-size: var(--fs-h2);
    max-width: 16ch;
  }
  .story__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--text-muted);
    max-width: 60ch;
  }
  .story__body p {
    line-height: 1.72;
  }

  .story__symbols {
    margin-top: 1rem;
  }
  .story__symbols ul {
    display: grid;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .symbol {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .symbol__ico {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border: 1px solid var(--hairline);
    border-radius: var(--r-sm);
    color: var(--palm);
  }
  .symbol__ico :global(.motif) {
    width: 1.4rem;
    height: 1.4rem;
  }
  .symbol__title {
    font-size: 1.1rem;
    margin-bottom: 0.15rem;
  }
  .symbol__desc {
    font-size: var(--fs-small);
    color: var(--text-muted);
    line-height: 1.55;
  }

  .story__media {
    position: relative;
  }
  .story__figure {
    position: relative;
    margin: 0;
    aspect-ratio: 4 / 5;
    max-width: 460px;
    margin-inline: auto;
    /* Ogee/pointed-arch mask */
    clip-path: path(
      'M0 100% L0 42% C0 18% 22% 0 50% 0 C78% 0 100% 18% 100% 42% L100% 100% Z'
    );
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .story__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .story__arch {
    position: absolute;
    inset: 0;
    border: 1px solid color-mix(in srgb, var(--brass) 55%, transparent);
    clip-path: path(
      'M0 100% L0 42% C0 18% 22% 0 50% 0 C78% 0 100% 18% 100% 42% L100% 100% Z'
    );
    pointer-events: none;
  }
  .story__caption {
    position: absolute;
    inset-block-end: -0.5rem;
    inset-inline-start: 50%;
    transform: translateX(-50%);
    background: var(--oud);
    color: var(--sand);
    padding: 0.4em 1.1em;
    border-radius: var(--r-pill);
    font-size: 0.66rem;
    white-space: nowrap;
  }
  [dir='rtl'] .story__caption {
    transform: translateX(50%);
  }

  @media (min-width: 900px) {
    .story {
      grid-template-columns: 1.1fr 0.9fr;
    }
    .story__symbols ul {
      gap: 1.75rem;
    }
  }
</style>
