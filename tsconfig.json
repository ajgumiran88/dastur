{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] },
    "types": ["vitest/globals"],
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": ["src", "vitest.config.ts", "astro.config.mjs"],
  "exclude": ["dist", "node_modules"]
}
